# ACAS Production Environment — copy to .env.prod and fill in secrets.
# Never commit .env.prod to version control.

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=change_me_strong_password
TIMESCALE_PASSWORD=change_me_strong_password

# ── MinIO ─────────────────────────────────────────────────────────────────────
MINIO_ROOT_USER=acasminio
MINIO_ROOT_PASSWORD=change_me_32chars_min

# ── JWT — generate with:  openssl rand -hex 64  OR use an RSA PEM for RS256 ──
JWT_SECRET_KEY=change_me_use_rsa_pem_for_rs256
JWT_ALGORITHM=RS256

# ── Kafka ─────────────────────────────────────────────────────────────────────
# Generate with:  docker run --rm apache/kafka:3.9.2 /opt/kafka/bin/kafka-storage.sh random-uuid
KAFKA_CLUSTER_ID=4L6g3nShT-eMCtK--X86sw

# ── Cloudflare Tunnel (recommended: token method) ─────────────────────────────
# Obtain from: https://one.dash.cloudflare.com → Access → Tunnels → Create tunnel
# Leave empty to use file-based config in ./config/cloudflared/config.yml
CLOUDFLARE_TUNNEL_TOKEN=

# ── Node identity ─────────────────────────────────────────────────────────────
NODE_ID=
NODE_NAME=acas-node-1

# ── GPU ───────────────────────────────────────────────────────────────────────
GPU_DEVICE_ID=0
NVIDIA_VISIBLE_DEVICES=all

# ── Control Plane (Cloudflare Workers URL) ────────────────────────────────────
CONTROL_PLANE_URL=https://acas-control.your-workers.dev

# ── Backup ────────────────────────────────────────────────────────────────────
BACKUP_RETAIN_DAYS=14

# ── Monitoring (optional — only used with --monitoring flag) ──────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=change_me
GRAFANA_ROOT_URL=http://localhost:3000
