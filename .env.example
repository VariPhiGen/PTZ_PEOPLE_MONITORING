# ── Host port overrides (defaults avoid conflicts on this machine) ──────────────
BACKEND_HOST_PORT=18000
POSTGRES_HOST_PORT=15432
TIMESCALE_HOST_PORT=5433
REDIS_HOST_PORT=16379
MINIO_API_HOST_PORT=19000
MINIO_CONSOLE_HOST_PORT=19001
KAFKA_HOST_PORT=9092
SCHEMA_REGISTRY_HOST_PORT=18081

# ── Service credentials ─────────────────────────────────────────────────────────
POSTGRES_PASSWORD=acas
TIMESCALE_PASSWORD=acas
MINIO_ROOT_USER=acasminio
MINIO_ROOT_PASSWORD=acasminiochange

# ── Kafka ───────────────────────────────────────────────────────────────────────
# Keep the default cluster ID or generate your own (22 chars, URL-safe base64).
KAFKA_CLUSTER_ID=4L6g3nShT-eMCtK--X86sw

# ── JWT ─────────────────────────────────────────────────────────────────────────
# RS256 (default): paste your RSA private-key PEM here (single line, \n escaped).
# HS256: use any long random string and set JWT_ALGORITHM=HS256.
JWT_SECRET_KEY=change-me-use-rsa-pem-for-rs256
JWT_ALGORITHM=RS256

# ── Node identity ───────────────────────────────────────────────────────────────
# Set NODE_ID to a stable UUID to persist identity across restarts.
# NODE_ID=<uuid>
NODE_NAME=acas-node-1

# ── GPU ─────────────────────────────────────────────────────────────────────────
NVIDIA_VISIBLE_DEVICES=all
GPU_DEVICE_ID=0
# Concurrent inference streams (3 for 16GB, 5 for 24GB+)
GPU_MAX_CONCURRENT=3
# VRAM budget in GB — headroom for FAISS + OS (total - 4GB is a good default)
GPU_VRAM_BUDGET_GB=20.0

# ── Optional control plane ──────────────────────────────────────────────────────
# CONTROL_PLANE_URL=https://acas-control-plane.your-subdomain.workers.dev
