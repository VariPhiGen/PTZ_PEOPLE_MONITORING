{
  "uid": "acas-overview",
  "title": "ACAS — Overview",
  "tags": ["acas"],
  "refresh": "10s",
  "time": {"from": "now-1h", "to": "now"},
  "timezone": "browser",
  "schemaVersion": 38,
  "panels": [
    {
      "id": 1, "type": "stat", "title": "Active Sessions",
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 0},
      "options": {"colorMode": "background", "graphMode": "area", "orientation": "auto"},
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"},
        "thresholds": {"steps": [{"color": "green", "value": 0}, {"color": "yellow", "value": 10}, {"color": "red", "value": 20}]}}},
      "targets": [{"datasource": {"uid": "acas-prometheus"}, "expr": "sum(acas_sessions_active)", "legendFormat": "sessions"}]
    },
    {
      "id": 2, "type": "stat", "title": "Faces Recognised / min",
      "gridPos": {"h": 4, "w": 4, "x": 4, "y": 0},
      "options": {"colorMode": "background", "graphMode": "area"},
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"},
        "thresholds": {"steps": [{"color": "blue", "value": 0}, {"color": "green", "value": 10}]},
        "unit": "short"}},
      "targets": [{"datasource": {"uid": "acas-prometheus"}, "expr": "round(sum(rate(acas_faces_recognized_total{outcome='KNOWN'}[1m])) * 60, 1)", "legendFormat": "known/min"}]
    },
    {
      "id": 3, "type": "stat", "title": "Recognition Rate",
      "gridPos": {"h": 4, "w": 4, "x": 8, "y": 0},
      "options": {"colorMode": "background"},
      "fieldConfig": {"defaults": {"unit": "percentunit", "color": {"mode": "thresholds"},
        "thresholds": {"steps": [{"color": "red", "value": 0}, {"color": "yellow", "value": 0.8}, {"color": "green", "value": 0.9}]}}},
      "targets": [{"datasource": {"uid": "acas-prometheus"}, "expr": "sum(rate(acas_faces_recognized_total{outcome='KNOWN'}[5m])) / sum(rate(acas_faces_recognized_total[5m]))", "legendFormat": "rate"}]
    },
    {
      "id": 4, "type": "stat", "title": "GPU Util",
      "gridPos": {"h": 4, "w": 4, "x": 12, "y": 0},
      "options": {"colorMode": "background"},
      "fieldConfig": {"defaults": {"unit": "percent", "color": {"mode": "thresholds"},
        "thresholds": {"steps": [{"color": "green", "value": 0}, {"color": "yellow", "value": 70}, {"color": "red", "value": 90}]}}},
      "targets": [{"datasource": {"uid": "acas-prometheus"}, "expr": "acas_gpu_util_percent", "legendFormat": "GPU {{device_id}}"}]
    },
    {
      "id": 5, "type": "stat", "title": "GPU VRAM Used",
      "gridPos": {"h": 4, "w": 4, "x": 16, "y": 0},
      "options": {"colorMode": "value"},
      "fieldConfig": {"defaults": {"unit": "bytes", "color": {"mode": "thresholds"},
        "thresholds": {"steps": [{"color": "green", "value": 0}, {"color": "yellow", "value": 17179869184}, {"color": "red", "value": 21474836480}]}}},
      "targets": [{"datasource": {"uid": "acas-prometheus"}, "expr": "acas_gpu_vram_used_bytes", "legendFormat": "VRAM"}]
    },
    {
      "id": 6, "type": "stat", "title": "Cameras Online",
      "gridPos": {"h": 4, "w": 4, "x": 20, "y": 0},
      "options": {"colorMode": "background"},
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"},
        "thresholds": {"steps": [{"color": "red", "value": 0}, {"color": "green", "value": 1}]}}},
      "targets": [{"datasource": {"uid": "acas-prometheus"}, "expr": "count(acas_camera_status == 1)", "legendFormat": "online"}]
    },
    {
      "id": 7, "type": "timeseries", "title": "Faces Recognised vs Unknown (rate/min)",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "fieldConfig": {"defaults": {"unit": "short"}},
      "options": {"tooltip": {"mode": "multi"}},
      "targets": [
        {"datasource": {"uid": "acas-prometheus"}, "expr": "sum(rate(acas_faces_recognized_total{outcome='KNOWN'}[1m])) * 60", "legendFormat": "Known"},
        {"datasource": {"uid": "acas-prometheus"}, "expr": "sum(rate(acas_faces_recognized_total{outcome='UNKNOWN'}[1m])) * 60", "legendFormat": "Unknown"},
        {"datasource": {"uid": "acas-prometheus"}, "expr": "sum(rate(acas_faces_recognized_total{outcome='LIVENESS_FAIL'}[1m])) * 60", "legendFormat": "Liveness Fail"}
      ]
    },
    {
      "id": 8, "type": "timeseries", "title": "Active Sessions by Mode",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "fieldConfig": {"defaults": {"unit": "short"}},
      "targets": [
        {"datasource": {"uid": "acas-prometheus"}, "expr": "sum by(mode)(acas_sessions_active)", "legendFormat": "{{mode}}"}
      ]
    },
    {
      "id": 9, "type": "table", "title": "Camera Status",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
      "options": {"showHeader": true},
      "fieldConfig": {"defaults": {"custom": {"filterable": true}}},
      "targets": [{"datasource": {"uid": "acas-prometheus"}, "expr": "acas_camera_status", "format": "table", "instant": true, "legendFormat": ""}],
      "transformations": [
        {"id": "organize", "options": {"excludeByName": {"Time": true, "__name__": true, "job": true, "instance": true}, "renameByName": {"room_name": "Room", "camera_id": "Camera ID", "client_id": "Client", "Value": "Status"}}}
      ]
    },
    {
      "id": 10, "type": "timeseries", "title": "Attendance Records Written / min",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
      "fieldConfig": {"defaults": {"unit": "short"}},
      "targets": [
        {"datasource": {"uid": "acas-prometheus"}, "expr": "sum by(status)(rate(acas_attendance_records_total[1m])) * 60", "legendFormat": "{{status}}"}
      ]
    }
  ]
}
