{
  "uid": "acas-ai-pipeline",
  "title": "ACAS — AI Pipeline",
  "tags": ["acas", "ai"],
  "refresh": "10s",
  "time": {"from": "now-30m", "to": "now"},
  "timezone": "browser",
  "schemaVersion": 38,
  "panels": [
    {
      "id": 1, "type": "stat", "title": "P50 Total Latency",
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 0},
      "fieldConfig": {"defaults": {"unit": "ms", "color": {"mode": "thresholds"},
        "thresholds": {"steps": [{"color": "green", "value": 0}, {"color": "yellow", "value": 60}, {"color": "red", "value": 200}]}}},
      "targets": [{"datasource": {"uid": "acas-prometheus"}, "expr": "histogram_quantile(0.50, rate(acas_pipeline_latency_seconds_bucket{stage='total'}[1m])) * 1000", "legendFormat": "p50"}]
    },
    {
      "id": 2, "type": "stat", "title": "P95 Total Latency",
      "gridPos": {"h": 4, "w": 4, "x": 4, "y": 0},
      "fieldConfig": {"defaults": {"unit": "ms", "color": {"mode": "thresholds"},
        "thresholds": {"steps": [{"color": "green", "value": 0}, {"color": "yellow", "value": 100}, {"color": "red", "value": 200}]}}},
      "targets": [{"datasource": {"uid": "acas-prometheus"}, "expr": "histogram_quantile(0.95, rate(acas_pipeline_latency_seconds_bucket{stage='total'}[1m])) * 1000", "legendFormat": "p95"}]
    },
    {
      "id": 3, "type": "stat", "title": "Faces/sec",
      "gridPos": {"h": 4, "w": 4, "x": 8, "y": 0},
      "fieldConfig": {"defaults": {"unit": "short", "color": {"mode": "thresholds"},
        "thresholds": {"steps": [{"color": "yellow", "value": 0}, {"color": "green", "value": 50}]}}},
      "targets": [{"datasource": {"uid": "acas-prometheus"}, "expr": "sum(rate(acas_faces_recognized_total[10s])) * 10", "legendFormat": "faces/s"}]
    },
    {
      "id": 4, "type": "stat", "title": "Face Hunt Success Rate",
      "gridPos": {"h": 4, "w": 4, "x": 12, "y": 0},
      "fieldConfig": {"defaults": {"unit": "percentunit", "color": {"mode": "thresholds"},
        "thresholds": {"steps": [{"color": "red", "value": 0}, {"color": "yellow", "value": 0.5}, {"color": "green", "value": 0.75}]}}},
      "targets": [{"datasource": {"uid": "acas-prometheus"}, "expr": "sum(rate(acas_face_hunt_total{outcome='SUCCESS'}[5m])) / sum(rate(acas_face_hunt_total[5m]))", "legendFormat": "hunt success"}]
    },
    {
      "id": 5, "type": "stat", "title": "GPU Degradation Mode",
      "gridPos": {"h": 4, "w": 4, "x": 16, "y": 0},
      "fieldConfig": {"defaults": {"mappings": [
        {"type": "value", "options": {"0": {"text": "FULL", "color": "green"}, "1": {"text": "NO_LIVENESS", "color": "yellow"}, "2": {"text": "EMBED_ONLY", "color": "orange"}, "3": {"text": "YOLO_ONLY", "color": "red"}}}
      ], "color": {"mode": "thresholds"}}},
      "targets": [{"datasource": {"uid": "acas-prometheus"}, "expr": "acas_gpu_degradation_mode", "legendFormat": "mode"}]
    },
    {
      "id": 6, "type": "stat", "title": "Liveness Fail %",
      "gridPos": {"h": 4, "w": 4, "x": 20, "y": 0},
      "fieldConfig": {"defaults": {"unit": "percentunit", "color": {"mode": "thresholds"},
        "thresholds": {"steps": [{"color": "green", "value": 0}, {"color": "yellow", "value": 0.10}, {"color": "red", "value": 0.20}]}}},
      "targets": [{"datasource": {"uid": "acas-prometheus"}, "expr": "sum(rate(acas_faces_recognized_total{outcome='LIVENESS_FAIL'}[5m])) / sum(rate(acas_faces_recognized_total[5m]))", "legendFormat": "fail%"}]
    },
    {
      "id": 7, "type": "timeseries", "title": "Per-Stage P50 Latency (ms)",
      "gridPos": {"h": 8, "w": 16, "x": 0, "y": 4},
      "fieldConfig": {"defaults": {"unit": "ms"}},
      "options": {"tooltip": {"mode": "multi"}},
      "targets": [
        {"datasource": {"uid": "acas-prometheus"}, "expr": "histogram_quantile(0.50, rate(acas_pipeline_latency_seconds_bucket{stage='yolo'}[1m])) * 1000", "legendFormat": "YOLO (target <18ms)"},
        {"datasource": {"uid": "acas-prometheus"}, "expr": "histogram_quantile(0.50, rate(acas_pipeline_latency_seconds_bucket{stage='retina'}[1m])) * 1000", "legendFormat": "RetinaFace (target <12ms)"},
        {"datasource": {"uid": "acas-prometheus"}, "expr": "histogram_quantile(0.50, rate(acas_pipeline_latency_seconds_bucket{stage='align'}[1m])) * 1000", "legendFormat": "Align"},
        {"datasource": {"uid": "acas-prometheus"}, "expr": "histogram_quantile(0.50, rate(acas_pipeline_latency_seconds_bucket{stage='adaface'}[1m])) * 1000", "legendFormat": "AdaFace (target <3ms/face)"},
        {"datasource": {"uid": "acas-prometheus"}, "expr": "histogram_quantile(0.50, rate(acas_pipeline_latency_seconds_bucket{stage='liveness'}[1m])) * 1000", "legendFormat": "MiniFASNet (target <10ms)"},
        {"datasource": {"uid": "acas-prometheus"}, "expr": "histogram_quantile(0.50, rate(acas_pipeline_latency_seconds_bucket{stage='total'}[1m])) * 1000", "legendFormat": "Total (target <60ms)"}
      ]
    },
    {
      "id": 8, "type": "heatmap", "title": "Pipeline Latency Distribution (total, ms)",
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 4},
      "options": {"calculate": false, "yAxis": {"unit": "ms", "decimals": 0}},
      "targets": [{"datasource": {"uid": "acas-prometheus"}, "expr": "sum(rate(acas_pipeline_latency_seconds_bucket{stage='total'}[1m])) by (le)", "format": "heatmap", "legendFormat": "{{le}}"}]
    },
    {
      "id": 9, "type": "timeseries", "title": "Face Hunt Outcomes / min",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
      "fieldConfig": {"defaults": {"unit": "short"}},
      "targets": [
        {"datasource": {"uid": "acas-prometheus"}, "expr": "sum by(outcome)(rate(acas_face_hunt_total[1m])) * 60", "legendFormat": "{{outcome}}"}
      ]
    },
    {
      "id": 10, "type": "timeseries", "title": "FAISS Search Latency P95 (ms)",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
      "fieldConfig": {"defaults": {"unit": "ms"}},
      "targets": [
        {"datasource": {"uid": "acas-prometheus"}, "expr": "histogram_quantile(0.95, rate(acas_faiss_search_latency_seconds_bucket{tier='gpu'}[5m])) * 1000", "legendFormat": "FAISS GPU (tier-1)"},
        {"datasource": {"uid": "acas-prometheus"}, "expr": "histogram_quantile(0.95, rate(acas_faiss_search_latency_seconds_bucket{tier='pgvector'}[5m])) * 1000", "legendFormat": "pgvector HNSW (tier-2)"}
      ]
    },
    {
      "id": 11, "type": "timeseries", "title": "Enrollment Quality Failures / min",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 20},
      "fieldConfig": {"defaults": {"unit": "short"}},
      "targets": [
        {"datasource": {"uid": "acas-prometheus"}, "expr": "sum by(reason)(rate(acas_enrollment_quality_fail_total[1m])) * 60", "legendFormat": "{{reason}}"}
      ]
    }
  ]
}
