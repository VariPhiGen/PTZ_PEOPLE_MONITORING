{
  "uid": "acas-ptz",
  "title": "ACAS — PTZ Intelligence",
  "tags": ["acas", "ptz"],
  "refresh": "30s",
  "time": {"from": "now-2h", "to": "now"},
  "timezone": "browser",
  "schemaVersion": 38,
  "panels": [
    {
      "id": 1, "type": "stat", "title": "Avg Cycle Time (last 5 min)",
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 0},
      "fieldConfig": {"defaults": {"unit": "s", "color": {"mode": "thresholds"},
        "thresholds": {"steps": [{"color": "green", "value": 0}, {"color": "yellow", "value": 30}, {"color": "red", "value": 60}]}}},
      "targets": [{"datasource": {"uid": "acas-prometheus"}, "expr": "histogram_quantile(0.50, rate(acas_session_cycle_duration_seconds_bucket[5m]))", "legendFormat": "p50 cycle"}]
    },
    {
      "id": 2, "type": "stat", "title": "P95 Cycle Time",
      "gridPos": {"h": 4, "w": 4, "x": 4, "y": 0},
      "fieldConfig": {"defaults": {"unit": "s", "color": {"mode": "thresholds"},
        "thresholds": {"steps": [{"color": "green", "value": 0}, {"color": "yellow", "value": 45}, {"color": "red", "value": 90}]}}},
      "targets": [{"datasource": {"uid": "acas-prometheus"}, "expr": "histogram_quantile(0.95, rate(acas_session_cycle_duration_seconds_bucket[5m]))", "legendFormat": "p95 cycle"}]
    },
    {
      "id": 3, "type": "stat", "title": "Avg Recognition Rate",
      "gridPos": {"h": 4, "w": 4, "x": 8, "y": 0},
      "fieldConfig": {"defaults": {"unit": "percentunit", "color": {"mode": "thresholds"},
        "thresholds": {"steps": [{"color": "red", "value": 0}, {"color": "yellow", "value": 0.8}, {"color": "green", "value": 0.9}]}}},
      "targets": [{"datasource": {"uid": "acas-prometheus"}, "expr": "avg(acas_session_recognition_rate)", "legendFormat": "avg rec rate"}]
    },
    {
      "id": 4, "type": "stat", "title": "Total Face Hunts / hr",
      "gridPos": {"h": 4, "w": 4, "x": 12, "y": 0},
      "fieldConfig": {"defaults": {"unit": "short", "color": {"mode": "value"}}},
      "targets": [{"datasource": {"uid": "acas-prometheus"}, "expr": "sum(rate(acas_face_hunt_total[1h])) * 3600", "legendFormat": "hunts/hr"}]
    },
    {
      "id": 5, "type": "stat", "title": "Hunt Duration P95",
      "gridPos": {"h": 4, "w": 4, "x": 16, "y": 0},
      "fieldConfig": {"defaults": {"unit": "s", "color": {"mode": "thresholds"},
        "thresholds": {"steps": [{"color": "green", "value": 0}, {"color": "yellow", "value": 10}, {"color": "red", "value": 15}]}}},
      "targets": [{"datasource": {"uid": "acas-prometheus"}, "expr": "histogram_quantile(0.95, rate(acas_face_hunt_duration_seconds_bucket[5m]))", "legendFormat": "p95 hunt"}]
    },
    {
      "id": 6, "type": "stat", "title": "Hunt Budget Exceeded / hr",
      "gridPos": {"h": 4, "w": 4, "x": 20, "y": 0},
      "fieldConfig": {"defaults": {"unit": "short", "color": {"mode": "thresholds"},
        "thresholds": {"steps": [{"color": "green", "value": 0}, {"color": "yellow", "value": 5}, {"color": "red", "value": 20}]}}},
      "targets": [{"datasource": {"uid": "acas-prometheus"}, "expr": "sum(rate(acas_face_hunt_total{outcome='BUDGET_EXCEEDED'}[1h])) * 3600", "legendFormat": "budget exceeded/hr"}]
    },
    {
      "id": 7, "type": "timeseries", "title": "Cycle Duration Percentiles (seconds)",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "fieldConfig": {"defaults": {"unit": "s"}},
      "options": {"tooltip": {"mode": "multi"}},
      "targets": [
        {"datasource": {"uid": "acas-prometheus"}, "expr": "histogram_quantile(0.50, rate(acas_session_cycle_duration_seconds_bucket[5m]))", "legendFormat": "p50"},
        {"datasource": {"uid": "acas-prometheus"}, "expr": "histogram_quantile(0.75, rate(acas_session_cycle_duration_seconds_bucket[5m]))", "legendFormat": "p75"},
        {"datasource": {"uid": "acas-prometheus"}, "expr": "histogram_quantile(0.95, rate(acas_session_cycle_duration_seconds_bucket[5m]))", "legendFormat": "p95"},
        {"datasource": {"uid": "acas-prometheus"}, "expr": "histogram_quantile(0.99, rate(acas_session_cycle_duration_seconds_bucket[5m]))", "legendFormat": "p99"}
      ]
    },
    {
      "id": 8, "type": "timeseries", "title": "Face Hunt Outcomes (rate/min)",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "fieldConfig": {"defaults": {"unit": "short"}},
      "targets": [
        {"datasource": {"uid": "acas-prometheus"}, "expr": "sum by(outcome)(rate(acas_face_hunt_total[1m])) * 60", "legendFormat": "{{outcome}}"}
      ]
    },
    {
      "id": 9, "type": "timeseries", "title": "Per-Session Recognition Rate",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
      "fieldConfig": {"defaults": {"unit": "percentunit", "min": 0, "max": 1}},
      "targets": [{"datasource": {"uid": "acas-prometheus"}, "expr": "acas_session_recognition_rate", "legendFormat": "{{session_id}}"}]
    },
    {
      "id": 10, "type": "heatmap", "title": "Face Hunt Duration Distribution",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
      "options": {"calculate": false, "yAxis": {"unit": "s"}},
      "targets": [{"datasource": {"uid": "acas-prometheus"}, "expr": "sum(rate(acas_face_hunt_duration_seconds_bucket[5m])) by (le)", "format": "heatmap", "legendFormat": "{{le}}"}]
    }
  ]
}
